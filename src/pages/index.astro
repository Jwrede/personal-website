---
import BaseLayout from '../layouts/BaseLayout.astro';
import Homepage from '../components/Homepage.astro';
import { t } from '../i18n/strings';

const tr = t('de');
---
<BaseLayout
  title={tr.siteTitle}
  description={tr.siteDescription}
  locale="de"
  ogType="profile"
  canonicalPath="/"
  alternates={{ de: '/', en: '/en/' }}
>
  <Homepage locale="de" />
</BaseLayout>
