---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { t, blogPostPath } from '../../../i18n/strings';

const locale = 'en';
const tr = t(locale);

const posts = (await getCollection('blog', ({ data }) => !data.draft && data.lang === locale))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = `${tr.blogTitle} | Jonathan Wrede`;
const description = tr.blogIndexDesc;

const fmt = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short', day: '2-digit' });

const blogJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  url: 'https://jonathanwrede.de/en/blog/',
  name: 'Jonathan Wrede, Blog',
  inLanguage: 'en',
  author: { '@type': 'Person', name: 'Jonathan Wrede' },
  blogPost: posts.map((p) => ({
    '@type': 'BlogPosting',
    headline: p.data.title,
    description: p.data.description,
    datePublished: p.data.pubDate.toISOString(),
    inLanguage: p.data.lang,
    url: `https://jonathanwrede.de${blogPostPath(locale, p.slug)}`,
  })),
};
---
<BaseLayout
  title={title}
  description={description}
  locale={locale}
  canonicalPath="/en/blog/"
  alternates={{ de: '/blog/', en: '/en/blog/' }}
  jsonLd={blogJsonLd}
>
  <div class="max-w-3xl mx-auto space-y-6">
    <header class="bg-card p-6 md:p-10 rounded-xl border-l-4 border-accent shadow-lg">
      <div class="flex items-center justify-between mb-4">
        <a href="/en/" class="text-xs text-slate-400 hover:text-accent font-mono inline-flex items-center">
          <i class="fas fa-arrow-left mr-1.5"></i> jonathanwrede.de
        </a>
        <a href="/blog/" hreflang="de" class="text-[11px] text-slate-400 hover:text-accent font-mono">DE</a>
      </div>
      <h1 class="text-3xl md:text-4xl font-bold mb-2">{tr.blogTitle}</h1>
      <p class="text-slate-400 text-sm md:text-base">{tr.blogTagline}</p>
    </header>

    <div class="space-y-3">
      {posts.length === 0 && (
        <p class="text-slate-500 font-mono text-sm">{tr.blogEmpty}</p>
      )}
      {posts.map((post) => (
        <a href={blogPostPath(locale, post.slug)} class="block bg-card rounded-xl p-5 md:p-6 border border-slate-700/50 hover:border-accent transition group shadow-lg">
          <div class="flex items-center gap-3 text-[11px] text-slate-500 font-mono mb-2">
            <time datetime={post.data.pubDate.toISOString()}>{fmt.format(post.data.pubDate)}</time>
            {post.data.tags.length > 0 && (
              <>
                <span class="text-slate-700">|</span>
                <span>{post.data.tags.slice(0, 3).join(' / ')}</span>
              </>
            )}
          </div>
          <h2 class="text-lg md:text-xl font-bold text-white group-hover:text-accent transition mb-2">
            {post.data.title}
          </h2>
          <p class="text-sm text-slate-400 leading-relaxed">{post.data.description}</p>
          <div class="mt-3 text-xs text-accent font-bold opacity-0 group-hover:opacity-100 transition">
            {tr.blogReadPost} <i class="fas fa-arrow-right ml-1"></i>
          </div>
        </a>
      ))}
    </div>

    <footer class="text-center text-slate-500 text-xs py-8">
      <a href="/en/" class="hover:text-accent">{tr.blogBackHome}</a>
    </footer>
  </div>
</BaseLayout>
