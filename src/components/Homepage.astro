    <script is:inline>
        function openModal(modalId) {
            const modal = document.getElementById(modalId);
            if (!modal) return;
            modal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }

        function closeModal(modalId) {
            const modal = document.getElementById(modalId);
            if (!modal) return;
            modal.classList.add('hidden');
            document.body.style.overflow = 'auto';
        }

        document.addEventListener('keydown', (e) => {
            if (e.key === "Escape") {
                ['cs0Modal', 'cs1Modal', 'cs2Modal', 'cs4Modal'].forEach(id => {
                    const el = document.getElementById(id);
                    if (el) el.classList.add('hidden');
                });
                document.body.style.overflow = 'auto';
            }
        });
    </script>

  <script is:inline define:vars={{ posts: teasersPayload, comingSoon: tr.comingSoon, readPost: tr.blogReadPost }}>
    (function () {
      const root = document.getElementById('blog-teasers');
      if (!root || !posts.length) {
        if (root) {
          root.innerHTML = '<p class="text-slate-500 text-sm font-mono">' + comingSoon + '</p>';
        }
        return;
      }
      root.innerHTML = posts.map(function (p) {
        const date = new Date(p.pubDate).toISOString().slice(0, 10);
        return '<a href="' + p.url + '" class="block bg-slate-800/40 rounded-lg p-4 border border-slate-700/50 hover:border-accent transition group">' +
               '<div class="text-[10px] text-slate-500 font-mono mb-1">' + date + '</div>' +
               '<h4 class="text-white font-bold group-hover:text-accent transition mb-1">' + p.title + '</h4>' +
               '<p class="text-xs text-slate-400 leading-relaxed">' + p.description + '</p>' +
               '</a>';
      }).join('');
    })();
  </script>
