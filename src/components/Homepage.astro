---
import { getCollection } from 'astro:content';
import { t, type Locale, blogPostPath, blogIndexPath, homePath } from '../i18n/strings';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const tr = t(locale);

const posts = (await getCollection('blog', ({ data }) => !data.draft && data.lang === locale))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const teasersPayload = posts.map((p) => ({
  url: blogPostPath(locale, p.id),
  title: p.data.title,
  description: p.data.description,
  pubDate: p.data.pubDate.toISOString(),
}));

const deActive = locale === 'de';
const enActive = locale === 'en';
const deBtnClass = deActive
  ? 'px-4 py-1.5 text-xs font-bold rounded-full transition-all duration-300 bg-accent text-bg shadow-[0_0_10px_rgba(56,189,248,0.4)]'
  : 'px-4 py-1.5 text-xs font-bold rounded-full text-slate-400 hover:text-white transition-all duration-300';
const enBtnClass = enActive
  ? 'px-4 py-1.5 text-xs font-bold rounded-full transition-all duration-300 bg-accent text-bg shadow-[0_0_10px_rgba(56,189,248,0.4)]'
  : 'px-4 py-1.5 text-xs font-bold rounded-full text-slate-400 hover:text-white transition-all duration-300';

const legalPath = locale === 'de' ? '/impressum/' : '/en/legal-notice/';
const privacyPath = locale === 'de' ? '/datenschutz/' : '/en/privacy/';
